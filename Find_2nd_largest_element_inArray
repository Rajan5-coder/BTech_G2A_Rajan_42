#include<stdio.h>
  int main(){
    int n,max,Smax;
    int a[100];
    printf("Enter the size of Array: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++){
        printf("Enter the value of a[%d] : ",i);
        scanf("%d",&a[i]);
    } 
      max = a[0];
    for(int i=0;i<n;i++){
        if(a[i]>max ){
            Smax = max;
            max = a[i];
        } 
        else if(a[i]>Smax && a[i]!=max){   // for when 2nd largest no. is present after largest no.
            Smax = a[i]; 
        }
    }
       printf("2nd largest no. is %d ",Smax);
  return 0;
}  
