#include<stdio.h>
int main(){
    float i,tax=0;
    printf("Enter the value of i: ");
    scanf("%f",&i);
    if(i<250000)     // 250000 -> 0%
        tax=0;
    if(i>250000 && i<=500000)    // 250000-500000 -> 5% 
        tax = 0.05*(i-250000);
    if(i>500000 && i<=1000000)   // 500000-1000000 -> 20%
        tax = 0.05*(500000-250000) + 0.2*(i-500000);
    if(i>1000000)                // > 1000000 -> 30%
        tax = 0.05*(500000-250000) + 0.2*(1000000-500000) + 0.3*(i-1000000);
    printf("%f",tax);

    return 0;
}
