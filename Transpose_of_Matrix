#include<stdio.h>
  int main(){

    int m,temp,n;     // m --> row , n--> coiumn
    printf("Enter the value of Row: ");
    scanf("%d",&m);

    printf("Enter the value of column: ");
    scanf("%d",&n);

    int a[m][n];
    printf("Enter the value of matrix:");
    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){         
            scanf("%d",&a[i][j]);
        }       
    }   
        printf("\n");

    for(int i=0;i<n;i++){
        for(int j=i;j<m;j++){ 
            temp = a[i][j];
            a[i][j] = a[j][i]; 
            a[j][i] = temp;       
           

        }
           printf("\n");
    }

     for(int i=0;i<n;i++){
        for(int j=0;j<m;j++){
                printf("%d  ",a[i][j]);
        }
         printf("\n");
    }
 return 0;
}
