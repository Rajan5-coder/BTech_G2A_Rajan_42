#include<stdio.h>
  int main(){
    int n,temp;
    printf("Enter the value of n: ");
    scanf("%d",&n);
    int a[n];
    for(int i=0;i<n;i++){
    printf("Enter the value of a[%d] : ",i);
    scanf("%d",&a[i]);
    } 
    for(int i=0;i<=n/2;i++){       
        temp = a[i];
        a[i] = a[n-1-i];
        a[n-1-i] = temp;           
    }
     for(int i=0;i<n;i++){
        printf("%d  ",a[i]);
     }

  return 0;
 }  
