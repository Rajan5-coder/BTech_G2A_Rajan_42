#include<stdio.h>
  int main(){
    int m,n;
     printf("Enter the value of m and n: ");
     scanf("%d %d",&m,&n);
     int a[m][n],b[m][n];
      printf("Enter the element of Matrix A: ");
    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            scanf("%d",&a[i][j]);
        }
    }
        printf("\n");
        printf("Enter the element of Matrix B: ");

    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
            scanf("%d",&b[i][j]);
        }
    }
    for(int i=0;i<m;i++){
        for(int j=0;j<n;j++){
           a[i][j] = a[i][j] + b[i][j];
           printf("%d  ",a[i][j]);
        }
        printf("\n");
    }

 return 0;
}
